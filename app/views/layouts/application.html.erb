<!DOCTYPE html>
<html>
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <%= stylesheet_link_tag "bootstrap.min", media: "all", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "simple_calendar", media: "all" %>
    <title><%= content_for(:title) || "Habit Tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="<%= pwa_manifest_path(format: :json) %>">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="shortcut icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-shell">
    <nav class="navbar navbar-dark app-nav">
      <div class="container py-2 d-flex justify-content-between align-items-center gap-3">
        <a class="navbar-brand brand-mark d-flex align-items-center gap-2 m-0" href="/">
          Habit Tracker
          <span class="brand-chip">Daily Focus</span>
        </a>

        <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
          <% if user_signed_in? %>
            <span class="text-white-50 small"><%= current_user.name.presence || "Minha conta" %> · <%= current_user.email %></span>
            <%= link_to "Minha conta", edit_user_registration_path, class: "btn btn-outline-light btn-sm px-3" %>
            <%= button_to "Sair", destroy_user_session_path, method: :delete,
                class: "btn btn-outline-light btn-sm px-3", form: { class: "d-inline-block m-0" } %>
          <% else %>
            <%= link_to "Login", new_user_session_path, class: "btn btn-outline-light btn-sm px-3" %>
            <%= link_to "Cadastrar", new_user_registration_path, class: "btn btn-light btn-sm px-3" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="container main-shell fade-up">
      <% if notice %>
        <div class="alert alert-success border-0 shadow-sm"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger border-0 shadow-sm"><%= alert %></div>
      <% end %>
      <%= yield %>
    </main>
    <%= javascript_include_tag "bootstrap.bundle.min", "data-turbo-track": "reload", defer: true %>
  </body>
</html>
