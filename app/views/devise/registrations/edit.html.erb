<section class="auth-login">
  <div class="auth-login__glow auth-login__glow--a" aria-hidden="true"></div>
  <div class="auth-login__glow auth-login__glow--b" aria-hidden="true"></div>

  <div class="auth-login__panel auth-login__panel--story surface-card">
    <p class="auth-kicker">Minha conta</p>
    <h1 class="auth-title">Atualize seu cadastro com seguranca.</h1>
    <p class="auth-subtitle">
      Aqui voce pode alterar nome, idade, e-mail e senha sempre que precisar.
    </p>

    <ul class="auth-points">
      <li>Edite seus dados pessoais</li>
      <li>Troque a senha quando quiser</li>
      <li>Mantenha seu acesso protegido</li>
    </ul>
  </div>

  <div class="auth-login__panel auth-login__panel--form surface-card">
    <div class="auth-form-head">
      <h2>Editar cadastro</h2>
      <p>Altere seus dados e confirme com a senha atual.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-3">
        <%= f.label :name, "Nome", class: "form-label auth-label" %>
        <%= f.text_field :name, autocomplete: "name", class: "form-control auth-input" %>
      </div>

      <div class="mb-3">
        <%= f.label :age, "Idade", class: "form-label auth-label" %>
        <%= f.number_field :age, min: 10, max: 120, class: "form-control auth-input" %>
      </div>

      <div class="mb-3">
        <%= f.label :email, "E-mail", class: "form-label auth-label" %>
        <%= f.email_field :email, autocomplete: "email", class: "form-control auth-input" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "Nova senha", class: "form-label auth-label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control auth-input", placeholder: "Deixe em branco para manter" %>
        <% if @minimum_password_length %>
          <div class="auth-hint mt-1">Minimo de <%= @minimum_password_length %> caracteres.</div>
        <% end %>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, "Confirmar nova senha", class: "form-label auth-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control auth-input" %>
      </div>

      <div class="mb-4">
        <%= f.label :current_password, "Senha atual", class: "form-label auth-label" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control auth-input", placeholder: "Obrigatorio para salvar" %>
      </div>

      <%= f.submit "Salvar alteracoes", class: "btn auth-submit w-100" %>
    <% end %>

    <div class="auth-links">
      <%= link_to "Voltar", habits_path %>
      <%= button_to "Excluir minha conta", registration_path(resource_name), method: :delete,
          data: { turbo_confirm: "Tem certeza? Essa acao nao pode ser desfeita." },
          class: "btn btn-outline-danger btn-sm",
          form: { class: "d-inline-block m-0" } %>
    </div>
  </div>
</section>
