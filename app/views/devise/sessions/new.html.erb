<section class="auth-login">
  <div class="auth-login__glow auth-login__glow--a" aria-hidden="true"></div>
  <div class="auth-login__glow auth-login__glow--b" aria-hidden="true"></div>

  <div class="auth-login__panel auth-login__panel--story surface-card">
    <p class="auth-kicker">Habit Tracker</p>
    <h1 class="auth-title">Transforme disciplina em resultado diario.</h1>
    <p class="auth-subtitle">
      Entre para acompanhar seus habitos, manter consistencia e ver seu progresso com clareza.
    </p>

    <ul class="auth-points">
      <li>Calendario de consistencia simples</li>
      <li>Historico de conclusoes em um clique</li>
      <li>Foco no que importa: continuidade</li>
    </ul>
  </div>

  <div class="auth-login__panel auth-login__panel--form surface-card">
    <div class="auth-form-head">
      <h2>Entrar</h2>
      <p>Use seu e-mail e senha para acessar sua rotina.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <div class="mb-3">
        <%= f.label :email, "E-mail", class: "form-label auth-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control auth-input", placeholder: "voce@exemplo.com" %>
      </div>

      <div class="mb-2">
        <%= f.label :password, "Senha", class: "form-label auth-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-control auth-input", placeholder: "Sua senha" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-check auth-check mb-3">
          <%= f.check_box :remember_me, class: "form-check-input" %>
          <%= f.label :remember_me, "Lembrar de mim", class: "form-check-label" %>
        </div>
      <% end %>

      <%= f.submit "Entrar", class: "btn auth-submit w-100" %>
    <% end %>

    <div class="auth-links">
      <% if devise_mapping.recoverable? %>
        <%= link_to "Esqueci minha senha", new_password_path(resource_name) %>
      <% end %>
      <% if devise_mapping.registerable? %>
        <%= link_to "Criar nova conta", new_registration_path(resource_name) %>
      <% end %>
    </div>
  </div>
</section>
