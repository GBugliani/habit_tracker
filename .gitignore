# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle
/vendor/bundle

# Ignore Ruby and tool caches.
/.byebug_history
/.yardoc
/_yardoc
/.ruby-lsp

# Ignore dependency manager and build logs.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore all environment files (except templates).
/.env*
!/.env*.erb

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore local coverage reports.
/coverage

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore local SQLite files when generated outside storage/.
/db/*.sqlite3
/db/*.sqlite3-*

/public/assets

# Ignore JavaScript dependencies if added locally.
/node_modules

# Ignore editor and OS-specific files.
/.idea
/.vscode
.DS_Store
Thumbs.db

# Ignore master key for decrypting credentials and more.
/config/master.key
/config/credentials/*.key
